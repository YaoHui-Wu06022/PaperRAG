# Embedding
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-m3

# MinerU Cloud
MINERU_API_TOKEN=your_mineru_token
MINERU_API_BASE_URL=https://mineru.net/api/v4
MINERU_CLOUD_MODEL_VERSION=pipeline
MINERU_CLOUD_POLL_INTERVAL_SEC=10
MINERU_CLOUD_TIMEOUT_SEC=900

# Milvus / Zilliz Cloud
VECTOR_BACKEND=milvus
MILVUS_URI=https://your-zilliz-endpoint
MILVUS_TOKEN=your_zilliz_token
MILVUS_COLLECTION=rag_pdf_chunks
MILVUS_REFERENCES_COLLECTION=rag_pdf_references
REFERENCES_STRATEGY=keyword_only

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=128
CHUNK_TOKENIZER_MODEL=BAAI/bge-m3
CHUNK_STRATEGY=semantic_paper
CHUNK_SEMANTIC_HARD_MAX_CHARS=2600
CHUNK_USE_STRUCTURE_SPLIT=true
CHUNK_MIN_BLOCK_CHARS=180
CHUNK_QUALITY_CHECK_ENABLED=true
CHUNK_QUALITY_HEADER_FOOTER_MIN_FREQ=3

# Retrieval
RETRIEVER_TOP_K=24
RETRIEVAL_MODE=hybrid
HYBRID_DENSE_TOP_K=20
HYBRID_BM25_TOP_K=20
HYBRID_RRF_K=60
METADATA_FILTER_ENABLED=true
QUERY_REWRITE_ENABLED=true
QUERY_REWRITE_MAX_VARIANTS=2
FINAL_TOP_K=6
RETRIEVAL_SCORE_THRESHOLD_MODE=absolute
RETRIEVAL_SCORE_THRESHOLD=0.2
RETRIEVAL_SCORE_RELATIVE_RATIO=0.7
RETRIEVAL_SCORE_QUANTILE=0.6

# Reranker
USE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_SCORE_THRESHOLD=none
RERANK_CONDITIONAL_ENABLED=false
DIVERSIFY_BY_SOURCE=true
MAX_CHUNKS_PER_SOURCE=3

# Generation
GENERATION_USE_PARENT_CONTEXT=true
GENERATION_PARENT_TOP_N=3
GENERATION_PARENT_MAX_CHARS=1800

# LLM (AIHubMix)
LLM_PROVIDER=aihubmix
LLM_MODEL=gpt-4.1-free
LLM_TEMPERATURE=0.1
AIHUBMIX_API_KEY=your_aihubmix_key
AIHUBMIX_BASE_URL=https://aihubmix.com/v1
AIHUBMIX_API_MODE=chat

# Optional advanced settings
# MILVUS_DB_NAME=
# REFERENCES_KEYWORD_INDEX_FILE=./data/cache/references_keyword_index.jsonl
# MINERU_OUTPUT_DIR=./data/mineru_output
# HF_ENDPOINT=https://hf-mirror.com
# HF_HOME=./data/hf_cache
# HF_HUB_DISABLE_XET=1
# HF_HUB_ETAG_TIMEOUT=60
# HF_HUB_DOWNLOAD_TIMEOUT=180
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_API_MODE=chat
# OLLAMA_BASE_URL=http://localhost:11434
